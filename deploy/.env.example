# Compose / gateway — copy to `deploy/.env` and adjust.

# Postgres (optional — without DATABASE_URL gateway skips persistence + vector retrieve)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/studio

# LiteLLM (optional upstream router — SPA still passes X-Upstream-Base-Url from browser)
LITELLM_MASTER_KEY=

# Gateway
PORT=8080
EMBEDDING_MODEL=text-embedding-3-small

# --- Hardening (production) ---
# Comma-separated browser Origins for CORS (omit for dev: reflect any origin).
# ALLOWED_ORIGINS=https://you.github.io,http://localhost:5173

# Comma-separated upstream API origins (scheme + host). When set, only these may be used in X-Upstream-Base-Url.
# ALLOWED_UPSTREAM_ORIGINS=https://api.openai.com

# Set to 1/true to reject loopback / RFC1918 hostnames when ALLOWED_UPSTREAM_ORIGINS is unset.
# GATEWAY_BLOCK_PRIVATE_UPSTREAM=1

# Max JSON body size (default 10mb).
# EXPRESS_JSON_LIMIT=10mb

# Static tool definitions merged into `/v1/tools/inventory` (JSON array OpenAI-format tools)
TOOLS_JSON=[]
# MCP-style prefixed tools surfaced in inventory (JSON array)
MCP_TOOLS_JSON=[]
